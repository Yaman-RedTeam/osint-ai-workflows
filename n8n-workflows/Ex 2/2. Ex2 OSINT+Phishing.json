    {
      "parameters": {
        "jsCode": "const input = ($node[\"When Chat Message Received\"].json.chatInput || '').trim();\n\nconst fromPattern = /(?:on\\s+)?([\\w\\s]+?)\\s+(?:from|at)\\s+([\\w\\s.]+)/i;\nconst m = input.match(fromPattern);\n\nlet targetName = '';\nlet company = '';\n\nif (m) {\n  targetName = m[1].replace(/^(do\\s+osint\\s+on|do\\s+osint|osint\\s+on|osint|research|find|on)\\s+/i, '').trim();\n  company = m[2].trim();\n} else {\n  const parts = input.split(',');\n  targetName = parts[0].replace(/^(do\\s+osint\\s+on|do\\s+osint|osint\\s+on|osint|research|find|on)\\s+/i, '').trim();\n  company = parts.length > 1 ? parts[1].trim() : '';\n}\n\nreturn [{ json: { targetName, company, companyClean: company.toLowerCase().replace(/[^a-z0-9]/g, ''), originalInput: input } }];"
      },
      "id": "e1-parse",
      "name": "Parse Target Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        -960,
