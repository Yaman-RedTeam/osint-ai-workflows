    {
      "parameters": {
        "jsCode": "const raw = $json.choices && $json.choices[0] && $json.choices[0].message ? $json.choices[0].message.content : 'No email generated.';\nconst target = $node['Parse Target Input'].json.targetName || 'Unknown';\nconst company = $node['Parse Target Input'].json.company || 'Unknown';\nconst divider = '\\u2500'.repeat(43);\nconst report = '🎯 **Targeted Phishing Payload Generated**\\n👤 **Target:** ' + target + ' (' + company + ')\\n\\n' + divider + '\\n\\n' + raw + '\\n\\n' + divider + '\\n📌 *Ready to copy-paste. For authorized security assessment purposes only.*';\nreturn [{ json: { formattedReport: report } }];"
